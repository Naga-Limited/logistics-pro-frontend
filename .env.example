# API Configuration
# Update these URLs based on your environment

# LOCAL DEVELOPMENT
REACT_APP_BASEURL=http://127.0.0.1:8000/api/v1
REACT_APP_BASEURL1=http://127.0.0.1:8000/api/v1/

# UAT/STAGING
# REACT_APP_BASEURL=https://uat-api.logisticspro.com/api/v1
# REACT_APP_BASEURL1=https://uat-api.logisticspro.com/api/v1/

# PRODUCTION
# REACT_APP_BASEURL=https://api.logisticspro.com/api/v1
# REACT_APP_BASEURL1=https://api.logisticspro.com/api/v1/

# Application Specific Configuration
REACT_APP_NLFS_DIESEL_VENDOR=231564
REACT_APP_NLFS_DIESEL_MATERIAL_CODE=SS126568

# Feature Flags (Optional)
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_DEBUG_MODE=true
REACT_APP_ENABLE_MAINTENANCE_MODE=false

# Session Configuration
REACT_APP_SESSION_TIMEOUT=1800000
REACT_APP_AUTO_LOGOUT_WARNING=300000

# Socket.io Configuration (if using real-time features)
REACT_APP_SOCKET_URL=http://127.0.0.1:8000
REACT_APP_SOCKET_PATH=/socket.io

# Third-party Services (Optional)
REACT_APP_GOOGLE_MAPS_API_KEY=
REACT_APP_ANALYTICS_ID=
REACT_APP_SENTRY_DSN=

# File Upload Limits
REACT_APP_MAX_FILE_SIZE=10485760
REACT_APP_ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx,xls,xlsx

# Pagination
REACT_APP_DEFAULT_PAGE_SIZE=10
REACT_APP_MAX_PAGE_SIZE=100

# Date Format
REACT_APP_DATE_FORMAT=DD/MM/YYYY
REACT_APP_TIME_FORMAT=HH:mm:ss
REACT_APP_DATETIME_FORMAT=DD/MM/YYYY HH:mm:ss

# Currency Settings
REACT_APP_CURRENCY=INR
REACT_APP_CURRENCY_SYMBOL=₹
